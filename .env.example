BIBLE_API_KEY=your_api_bible_key_here

# Optional aliases (any one works):
# BIBLE_API=
# API_BIBLE_KEY=
# API_BIBLE=

# Base URL (default: https://rest.api.bible)
# API_BIBLE_BASE_URL=https://rest.api.bible
